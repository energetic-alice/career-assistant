# Server
PORT=3000
WEBHOOK_SECRET=your-webhook-secret-here

# Anthropic Claude API
ANTHROPIC_API_KEY=your-anthropic-api-key

# Google (один из двух вариантов)
GOOGLE_SERVICE_ACCOUNT_KEY=path-to-service-account.json
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Google Drive (папка для финальных документов)
GOOGLE_DRIVE_FOLDER_ID=your-folder-id

# Google Apps Script Web App (создание Google Doc от имени пользователя, обходит квоту SA)
# APPS_SCRIPT_DOC_URL=https://script.google.com/macros/s/.../exec

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_ADMIN_CHAT_ID=your-chat-id

# Production only: публичный URL сервера (включает Telegram webhook)
# APP_URL=https://your-app.onrender.com
